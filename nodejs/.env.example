# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# SQL Server connection info (adjust values to match your local SQL Server instance)
MSSQL_SERVER='localhost\\SQLEXPRESS'
MSSQL_USER='your_local_sql_user'
MSSQL_PASSWORD='your_local_sql_password'
MSSQL_DATABASE='LearningManagementSystem'

# Prisma Database connection URL (SQL Server format)
DATABASE_URL="sqlserver://localhost:1433;database=LearningManagementSystem;user=your_local_sql_user;password=your_local_sql_password;trustServerCertificate=true;encrypt=false"

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
LOCAL_DEV_APP_HOST='localhost'
LOCAL_DEV_APP_PORT=8017
AUTHOR='YourName'

# -----------------------------------------------------------------------------
# DOMAINS & CORS CONFIGURATION
# -----------------------------------------------------------------------------
# Set this to the port your React dev server is running on (e.g., http://localhost:5173 or http://localhost:5174)
WEBSITE_DOMAIN_DEVELOPMENT='http://localhost:5173'
WEBSITE_DOMAIN_PRODUCTION='https://your-production-app.vercel.app'

# -----------------------------------------------------------------------------
# EMAIL SERVICE (BREVO / SENDINBLUE)
# -----------------------------------------------------------------------------
# Sign up at Brevo.com to get your own API Key. Keep this secret and DO NOT commit your live key.
BREVO_API_KEY='your_brevo_api_key_here'
ADMIN_EMAIL_ADDRESS='your_admin_email@example.com'
ADMIN_EMAIL_NAME='LMS System Admin'

# -----------------------------------------------------------------------------
# JWT (JSON WEB TOKEN) SIGNATURES
# -----------------------------------------------------------------------------
# Change these secret signatures to strong, random keys in production
ACCESS_TOKEN_SECRET_SIGNATURE='your_access_token_secret_here'
ACCESS_TOKEN_LIFE='1h'

REFRESH_TOKEN_SECRET_SIGNATURE='your_refresh_token_secret_here'
REFRESH_TOKEN_LIFE='14 days'
