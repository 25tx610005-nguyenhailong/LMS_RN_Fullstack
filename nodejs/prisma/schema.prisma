generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Account {
  Id                     String                   @id(map: "PK_Account") @db.UniqueIdentifier
  UserName               String?                  @db.NVarChar(100)
  FullName               String?                  @db.NVarChar(100)
  BirthDay               DateTime?                @db.Date
  IdGender               Int?
  PasswordSalt           String?                  @db.NVarChar(128)
  Password               String?                  @db.NVarChar(128)
  Active                 Boolean?
  ActiveToken            String?                  @db.UniqueIdentifier
  Phone                  String?                  @db.NVarChar(11)
  Email                  String?                  @db.NVarChar(100)
  Provider               String?                  @db.NVarChar(20)
  Address                String?                  @db.NVarChar(500)
  IdCity                 Int?
  IdDistrict             Int?
  LinkAvatar             String?                  @db.NVarChar(500)
  Deleted                Int?
  Created_By             String?                  @db.NVarChar(50)
  Created_Date           DateTime?                @db.DateTime
  Modified_By            String?                  @db.NVarChar(50)
  Modified_Date          DateTime?                @db.DateTime
  Gender                 Gender?                  @relation(fields: [IdGender], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Account_Gender")
  AccountCertificate     AccountCertificate[]
  AccountInRole          AccountInRole[]
  AccountSalary          AccountSalary[]
  AccountStudent         AccountStudent[]
  AccountWorkingTime     AccountWorkingTime[]
  CourseSchedule         CourseSchedule[]
  CourseScheduleDetail   CourseScheduleDetail[]
  CourseStudent          CourseStudent[]
  MaterialLessonResource MaterialLessonResource[]
  SchoolTeacher          SchoolTeacher[]
}

model AccountCertificate {
  Id              Int       @id(map: "PK_AccountCertificate") @default(autoincrement())
  IdAccount       String?   @db.UniqueIdentifier
  CertificateName String?   @db.NVarChar(255)
  Organization    String?   @db.NVarChar(255)
  IssueDate       DateTime? @db.Date
  ExpiryDate      DateTime? @db.Date
  Description     String?   @db.NVarChar(500)
  FileUrl         String?   @db.NVarChar(500)
  CreatedDate     DateTime? @default(now(), map: "DF__AccountCe__Creat__2EDAF651") @db.DateTime
  CreatedBy       String?   @db.NVarChar(100)
  Account         Account?  @relation(fields: [IdAccount], references: [Id], onDelete: NoAction, onUpdate: NoAction, map: "FK_AccountCertificate_Account")
}

